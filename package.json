{
  "name": "telegramfreerich",
  "version": "3.0.0",
  "description": "Free Rich Text Editor for Telegram — Desktop Edition",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder build --win --publish never",
    "build:linux": "electron-builder build --linux --publish never"
  },
  "build": {
    "appId": "com.aporis.telegramfreerich",
    "productName": "TelegramFreeRich",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^24.13.3"
  }
}
