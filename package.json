{
  "name": "telegramfreerich",
  "version": "2.0.0",
  "description": "Free Rich Text Editor for Telegram — Desktop Edition",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder build --win",
    "build:linux": "electron-builder build --linux"
  },
  "publish": null,"build": {
    "appId": "com.aporis.telegramfreerich",
    "productName": "TelegramFreeRich",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "src/renderer/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0"
  }
}
